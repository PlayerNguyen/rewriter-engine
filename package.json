{
  "name": "rewriter",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "build": "bun run --filter '*' build",
    "storybook": "bun run --filter @rewriter/ui storybook",
    "build-storybook": "bun run --filter @rewriter/ui build-storybook",
    "dev:dashboard": "bun run --filter @rewriter/dashboard dev"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  }
}
