{
  "name": "rewriter",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "packages/settings/*",
    "apps/*"
  ],
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "build": "bun run --filter '*' build",
    "storybook": "bun run --filter @rewriter/ui storybook",
    "build-storybook": "bun run --filter @rewriter/ui build-storybook",
    "dev:dashboard": "bun run --filter @rewriter/dashboard dev",
    "dev:server": "bun run --filter @rewriter/server dev",
    "lint": "bunx --bun @biomejs/biome check .",
    "lint:fix": "bunx --bun @biomejs/biome check --write .",
    "format": "bunx --bun @biomejs/biome format --write .",
    "format:check": "bunx --bun @biomejs/biome format .",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "bun run prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:e2e": "bun run --filter '@rewriter/server' test:e2e",
    "generate:spec": "bun run --filter @rewriter/server generate:spec",
    "generate:client": "bun run generate:spec && bun run --filter @rewriter/rest-client generate",
    "generate": "bun run generate:client"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/bun": "latest",
    "prisma": "^7.8.0",
    "typescript": "^5"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "pg": "^8.22.0"
  }
}
