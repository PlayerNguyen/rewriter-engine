{
  "openapi": "3.1.0",
  "info": {
    "title": "Rewriter API",
    "description": "API for the content rewriter pipeline",
    "version": "0.0.1"
  },
  "servers": [
    {
      "url": "http://localhost:3001",
      "description": "Local Dev"
    }
  ],
  "paths": {
    "/api/v1/table": {
      "get": {
        "responses": {
          "200": {
            "description": "Paginated table data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {}
                    },
                    "total": {
                      "type": "number"
                    },
                    "page": {
                      "type": "number"
                    },
                    "limit": {
                      "type": "number"
                    },
                    "totalPages": {
                      "type": "number"
                    }
                  },
                  "required": ["data", "total", "page", "limit", "totalPages"]
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": ["error"]
                }
              }
            }
          },
          "404": {
            "description": "No handler found for the given table id",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": ["error"]
                }
              }
            }
          }
        },
        "operationId": "getApiV1Table",
        "tags": ["Table"],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "Table identifier (e.g. \"sources\", \"articles\")",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number (1-based, default: 1)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Results per page (default: 20)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 20
            }
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "description": "JSON-encoded sort: {\"fieldName\":\"createdAt\",\"direction\":\"desc\"}",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "search",
            "in": "query",
            "required": false,
            "description": "Full-text search term",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filters",
            "in": "query",
            "required": false,
            "description": "JSON-encoded key-value filters: {\"type\":\"news\"}",
            "schema": {
              "type": "string"
            }
          }
        ],
        "description": "Query a registered table with pagination, sorting, search, and filters"
      }
    },
    "/api/v1/health": {
      "get": {
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "timestamp": {
                      "type": "string"
                    }
                  },
                  "required": ["status", "timestamp"]
                }
              }
            }
          }
        },
        "operationId": "getApiV1Health",
        "tags": ["Health"],
        "parameters": [],
        "description": "Health check endpoint"
      }
    },
    "/api/v1/parsers": {
      "get": {
        "responses": {
          "200": {
            "description": "List of parsers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "key": {
                        "type": "string"
                      },
                      "name": {
                        "type": "string"
                      },
                      "urlPatterns": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    },
                    "required": ["key", "name", "urlPatterns"]
                  }
                }
              }
            }
          }
        },
        "operationId": "getApiV1Parsers",
        "tags": ["Parsers"],
        "parameters": [],
        "description": "List all available parsers"
      }
    },
    "/api/v1/settings/{key}": {
      "patch": {
        "responses": {
          "200": {
            "description": "Setting updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "key": {
                      "type": "string"
                    },
                    "value": {},
                    "updatedAt": {
                      "type": "string"
                    }
                  },
                  "required": ["id", "key", "updatedAt"]
                }
              }
            }
          },
          "404": {
            "description": "Setting not found"
          }
        },
        "operationId": "patchApiV1SettingsByKey",
        "tags": ["Settings"],
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "key",
            "required": true
          }
        ],
        "description": "Update a setting value by key",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "value": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "number"
                      },
                      {
                        "type": "boolean"
                      },
                      {
                        "type": "object",
                        "additionalProperties": {}
                      },
                      {
                        "type": "array",
                        "items": {}
                      }
                    ]
                  }
                },
                "required": ["value"]
              }
            }
          }
        }
      }
    },
    "/api/v1/sources": {
      "post": {
        "responses": {
          "201": {
            "description": "Source created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "format": "uuid"
                    },
                    "name": {
                      "type": "string"
                    },
                    "url": {
                      "type": "string"
                    },
                    "type": {
                      "type": "string",
                      "enum": ["RSS", "WEB", "API"]
                    },
                    "isActive": {
                      "type": "boolean"
                    },
                    "parserKey": {
                      "type": ["string", "null"]
                    },
                    "requestDelayMs": {
                      "type": "number"
                    },
                    "lastFetched": {
                      "type": ["string", "null"]
                    },
                    "createdAt": {
                      "type": "string"
                    },
                    "updatedAt": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "id",
                    "name",
                    "url",
                    "type",
                    "isActive",
                    "parserKey",
                    "requestDelayMs",
                    "lastFetched",
                    "createdAt",
                    "updatedAt"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          }
        },
        "operationId": "postApiV1Sources",
        "tags": ["Sources"],
        "parameters": [],
        "description": "Create a new content source",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "type": {
                    "type": "string",
                    "enum": ["RSS", "WEB", "API"],
                    "default": "RSS"
                  },
                  "isActive": {
                    "type": "boolean",
                    "default": true
                  },
                  "parserKey": {
                    "type": ["string", "null"]
                  },
                  "requestDelayMs": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 1000
                  }
                },
                "required": ["name", "url"]
              }
            }
          }
        }
      }
    },
    "/api/v1/sources/{id}": {
      "patch": {
        "responses": {
          "200": {
            "description": "Source updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "format": "uuid"
                    },
                    "name": {
                      "type": "string"
                    },
                    "url": {
                      "type": "string"
                    },
                    "type": {
                      "type": "string",
                      "enum": ["RSS", "WEB", "API"]
                    },
                    "isActive": {
                      "type": "boolean"
                    },
                    "parserKey": {
                      "type": ["string", "null"]
                    },
                    "requestDelayMs": {
                      "type": "number"
                    },
                    "lastFetched": {
                      "type": ["string", "null"]
                    },
                    "createdAt": {
                      "type": "string"
                    },
                    "updatedAt": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "id",
                    "name",
                    "url",
                    "type",
                    "isActive",
                    "parserKey",
                    "requestDelayMs",
                    "lastFetched",
                    "createdAt",
                    "updatedAt"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          },
          "404": {
            "description": "Source not found"
          }
        },
        "operationId": "patchApiV1SourcesById",
        "tags": ["Sources"],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true
          }
        ],
        "description": "Update an existing source",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "type": {
                    "type": "string",
                    "enum": ["RSS", "WEB", "API"]
                  },
                  "isActive": {
                    "type": "boolean"
                  },
                  "parserKey": {
                    "type": ["string", "null"]
                  },
                  "requestDelayMs": {
                    "type": "integer",
                    "minimum": 0
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "responses": {
          "200": {
            "description": "Source deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "format": "uuid"
                    },
                    "name": {
                      "type": "string"
                    },
                    "url": {
                      "type": "string"
                    },
                    "type": {
                      "type": "string",
                      "enum": ["RSS", "WEB", "API"]
                    },
                    "isActive": {
                      "type": "boolean"
                    },
                    "parserKey": {
                      "type": ["string", "null"]
                    },
                    "requestDelayMs": {
                      "type": "number"
                    },
                    "lastFetched": {
                      "type": ["string", "null"]
                    },
                    "createdAt": {
                      "type": "string"
                    },
                    "updatedAt": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "id",
                    "name",
                    "url",
                    "type",
                    "isActive",
                    "parserKey",
                    "requestDelayMs",
                    "lastFetched",
                    "createdAt",
                    "updatedAt"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          },
          "404": {
            "description": "Source not found"
          }
        },
        "operationId": "deleteApiV1SourcesById",
        "tags": ["Sources"],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true
          }
        ],
        "description": "Delete a source"
      }
    }
  },
  "components": {
    "schemas": {}
  }
}
