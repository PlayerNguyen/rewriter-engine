{
  "name": "@rewriter/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "bun test __e2e__/",
    "generate:spec": "bun run scripts/generate-openapi.ts && bunx biome format --write openapi.json"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.1.0",
    "@hono/structured-logger": "^0.1.0",
    "@hono/zod-validator": "^0.7.0",
    "@prisma/client": "^7.8.0",
    "@rewriter/db": "workspace:*",
    "@rewriter/logger": "workspace:*",
    "@rewriter/settings": "workspace:*",
    "@rewriter/table-core": "workspace:*",
    "@scalar/hono-api-reference": "^0.7.0",
    "hono": "^4",
    "hono-openapi": "^0.4.0",
    "openapi-types": "^12.1.3",
    "zod": "^3.23.0",
    "zod-openapi": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
