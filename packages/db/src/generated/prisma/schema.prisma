generator client {
  provider = "prisma-client-js"
  output   = "../packages/db/src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Admin Users ────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles UserHasRole[]

  @@map("users")
}

model Role {
  id          String  @id @default(uuid())
  name        String
  description String?

  users       UserHasRole[]
  permissions RoleHasPermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("roles")
}

model Permission {
  id          String @id @default(uuid())
  name        String @unique
  description Json

  roles RoleHasPermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("permissions")
}

model UserHasRole {
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_has_roles")
}

model RoleHasPermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_has_permissions")
}

// ─── Content Sources ────────────────────────────────────────────

model Source {
  id             String     @id @default(uuid())
  name           String
  url            String
  type           SourceType @default(RSS)
  isActive       Boolean    @default(true)
  parserKey      String? // Override parser key (e.g. "tuoitre-normal"). Null = auto-detect.
  requestDelayMs Int        @default(1000) // Delay between HTTP requests to this source (ms)
  lastFetched    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  articles     Article[]
  exploredUrls ExploredUrl[]

  @@map("sources")
}

enum SourceType {
  RSS
  WEB
  API
}

// ─── System Prompts ─────────────────────────────────────────────

model SystemPrompt {
  id          String   @id @default(uuid())
  name        String
  content     String   @db.Text
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rewrittenArticles RewrittenArticle[]

  @@map("system_prompts")
}

// ─── Articles (raw from Explorer) ───────────────────────────────

model Article {
  id           String        @id @default(uuid())
  title        String
  content      String        @db.Text
  url          String        @unique
  author       String?
  publishedAt  DateTime?
  fetchedAt    DateTime      @default(now())
  status       ArticleStatus @default(PENDING)
  errorMessage String?       @db.Text

  sourceId String
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  rewrittenArticle RewrittenArticle?

  createdAt DateTime @default(now())

  @@index([sourceId, status])
  @@index([status])
  @@map("articles")
}

enum ArticleStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── Explored URLs (from deep exploration) ──────────────────────

model ExploredUrl {
  id           String            @id @default(uuid())
  url          String            @unique
  title        String?
  depth        Int               @default(0)
  status       ExploredUrlStatus @default(PENDING)
  errorMessage String?           @db.Text
  parentUrl    String?

  sourceId String
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sourceId, status])
  @@index([status])
  @@index([url])
  @@map("explored_urls")
}

enum ExploredUrlStatus {
  PENDING
  PROCESSING
  EXPLORED
  FAILED
  SKIPPED
}

// ─── Rewritten Articles (output from LLM) ───────────────────────

model RewrittenArticle {
  id             String   @id @default(uuid())
  title          String
  content        String   @db.Text
  llmModel       String
  tokensUsed     Int?
  processingTime Int? // milliseconds
  createdAt      DateTime @default(now())

  originalArticleId String  @unique
  originalArticle   Article @relation(fields: [originalArticleId], references: [id], onDelete: Cascade)

  systemPromptId String
  systemPrompt   SystemPrompt @relation(fields: [systemPromptId], references: [id])

  @@index([systemPromptId])
  @@index([createdAt])
  @@map("rewritten_articles")
}

// ─── System Settings ────────────────────────────────────────────

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}
