{
  "name": "@rewriter/rest-client",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./api/*": "./src/generated/api/*.ts",
    "./model/*": "./src/generated/model/*.ts"
  },
  "scripts": {
    "generate": "orval --config ./orval.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "orval": "^8",
    "typescript": "^5"
  }
}
