{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,

    // Path aliases
    "paths": {
      "@rewriter/ui": ["./packages/ui/src/index.ts"],
      "@rewriter/ui/*": ["./packages/ui/src/*"],
      "@rewriter/db": ["./packages/db/src/index.ts"],
      "@rewriter/db/*": ["./packages/db/src/*"],
      "@rewriter/logger": ["./packages/logger/src/index.ts"],
      "@rewriter/logger/*": ["./packages/logger/src/*"],
      "@rewriter/table": ["./packages/table/src/index.ts"],
      "@rewriter/table/*": ["./packages/table/src/*"]
    }
  }
}
