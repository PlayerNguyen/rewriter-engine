{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,

    // Path aliases
    "paths": {
      "@rewriter/ui": ["./packages/ui/src/index.ts"],
      "@rewriter/ui/*": ["./packages/ui/src/*"],
      "@rewriter/db": ["./packages/db/src/index.ts"],
      "@rewriter/db/*": ["./packages/db/src/*"],
      "@rewriter/logger": ["./packages/logger/src/index.ts"],
      "@rewriter/logger/*": ["./packages/logger/src/*"],
      "@rewriter/table-core": ["./packages/table-core/src/index.ts"],
      "@rewriter/table-core/*": ["./packages/table-core/src/*"],
      "@rewriter/rest-client": ["./packages/rest-client/src/index.ts"],
      "@rewriter/rest-client/*": ["./packages/rest-client/src/*"],
      "@rewriter/table-ui": ["./packages/table-ui/src/index.ts"],
      "@rewriter/table-ui/*": ["./packages/table-ui/src/*"],
      "@rewriter/modal": ["./packages/modal/src/index.tsx"],
      "@rewriter/modal/*": ["./packages/modal/src/*"],
      "@rewriter/settings": ["./packages/settings/core/src/index.ts"],
      "@rewriter/settings/*": ["./packages/settings/core/src/*"],
      "@rewriter/settings-ui": ["./packages/settings/ui/src/index.tsx"],
      "@rewriter/settings-ui/*": ["./packages/settings/ui/src/*"],
      "@rewriter/sources": ["./packages/sources/core/src/index.ts"],
      "@rewriter/sources/*": ["./packages/sources/core/src/*"],
      "@rewriter/sources-ui": ["./packages/sources/ui/src/index.tsx"],
      "@rewriter/sources-ui/*": ["./packages/sources/ui/src/*"],
      "@rewriter/parser": ["./packages/parser/src/index.ts"],
      "@rewriter/parser/*": ["./packages/parser/src/*"]
    }
  }
}
